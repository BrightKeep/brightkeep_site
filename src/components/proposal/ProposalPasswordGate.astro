---
interface Props {
  error?: boolean;
}

const { error = false } = Astro.props;
---

<div class="min-h-screen flex items-center justify-center bg-[#1B2A4A] px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <img
        src="/proposals/brightkeep-logo.png"
        alt="BrightKeep"
        class="h-12 mx-auto mb-6"
      />
      <h1 class="text-2xl font-bold text-white mb-2">Proposal Access</h1>
      <p class="text-white/70 text-sm">Enter the password to view this proposal.</p>
    </div>

    <form method="POST" class="bg-white/10 backdrop-blur rounded-xl p-8 border border-white/20">
      {error && (
        <div class="mb-4 p-3 rounded-lg bg-red-500/20 border border-red-400/30 text-red-200 text-sm text-center">
          Incorrect password. Please try again.
        </div>
      )}

      <label for="password" class="block text-sm font-medium text-white/80 mb-2">
        Password
      </label>
      <input
        type="password"
        id="password"
        name="password"
        required
        autofocus
        class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-[#FF6B6B] focus:border-transparent transition-colors"
        placeholder="Enter password"
      />

      <button
        type="submit"
        class="w-full mt-4 bg-[#FF6B6B] text-white font-semibold px-6 py-3 rounded-lg hover:bg-[#FF5252] transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        View Proposal
      </button>
    </form>

    <p class="text-center text-white/40 text-xs mt-6">
      Prepared for Cloud9 Consulting by BrightKeep
    </p>
  </div>
</div>
