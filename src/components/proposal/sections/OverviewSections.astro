        <p class="text-sm text-[#6B7280]">Delivery Model</p>
      </div>
    </div>

    <!-- Operations -->
    <h4 class="text-lg font-semibold text-[#1B2A4A] mt-6 mb-3">Operations</h4>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
        <svg class="w-8 h-8 mx-auto mb-2 text-[#FF6B6B]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
