    <!-- Scale -->
    <h4 class="text-lg font-semibold text-[#1B2A4A] mt-6 mb-3">Scale</h4>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
        <svg class="w-8 h-8 mx-auto mb-2 text-[#FF6B6B]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
        </svg>
        <p class="text-lg font-bold text-[#1B2A4A]">~$376/mo</p>
        <p class="text-sm text-[#6B7280]">Cost at 5 Clients</p>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
        <svg class="w-8 h-8 mx-auto mb-2 text-[#FF6B6B]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
        </svg>
        <p class="text-lg font-bold text-[#1B2A4A]">~18 clients</p>
        <p class="text-sm text-[#6B7280]">Multi-Tenant Crossover</p>
      </div>
      <div class="bg-white rounded-lg border border-gray-200 p-4 text-center">
        <svg class="w-8 h-8 mx-auto mb-2 text-[#FF6B6B]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
