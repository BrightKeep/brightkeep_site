---
export const prerender = false;

import ProposalLayout from '../../layouts/ProposalLayout.astro';
import ProposalHeader from '../../components/proposal/ProposalHeader.astro';
import ProposalSidebarV2 from '../../components/proposal/ProposalSidebarV2.astro';
import ProposalPasswordGate from '../../components/proposal/ProposalPasswordGate.astro';

const COOKIE_NAME = 'proposal_cloud9_auth';
const COOKIE_VALUE = 'authenticated';
const PASSWORD = import.meta.env.PROPOSAL_CLOUD9_PASSWORD || 'cloud9proposal';

let authenticated = false;
let showError = false;

const cookie = Astro.request.headers.get('cookie') || '';
if (cookie.includes(`${COOKIE_NAME}=${COOKIE_VALUE}`)) {
  authenticated = true;
}

if (Astro.request.method === 'POST' && !authenticated) {
  const formData = await Astro.request.formData();
  const submittedPassword = formData.get('password');

  if (submittedPassword === PASSWORD) {
    authenticated = true;
    Astro.cookies.set(COOKIE_NAME, COOKIE_VALUE, {
      path: '/proposals',
      maxAge: 60 * 60 * 24 * 7,
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: 'lax',
    });
  } else {
    showError = true;
  }
}
---

<ProposalLayout>
  {!authenticated ? (
    <ProposalPasswordGate error={showError} />
  ) : (
    <>
      <ProposalHeader version="v2" />
      <ProposalSidebarV2 />

      <main class="pt-16 lg:pl-64 min-h-screen">

        <!-- Print-only branded cover page -->
        <section id="print-cover" aria-hidden="true">
          <div class="print-cover-logo-wrap">
            <span class="print-cover-logo-bright">Bright</span><span class="print-cover-logo-keep">Keep</span>
          </div>

          <div class="print-cover-tag-wrap">
            <span class="print-cover-tag">Updated Proposal &middot; v2.0</span>
          </div>

          <div class="print-cover-title-wrap">
            <h1 class="print-cover-title">Cloud9 Visualisation Tool</h1>
            <p class="print-cover-subtitle">MVP Build Proposal (V2)</p>
            <div class="print-cover-rule"></div>
            <p class="print-cover-date">May 2026</p>
          </div>

          <div class="print-cover-foot">
            <p class="print-cover-foot-left">Prepared for Cloud9 Consulting</p>
            <p class="print-cover-foot-right">brightkeep.com.au</p>
          </div>
        </section>

        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
          <!-- Cover / title block -->
          <div id="proposal-cover" class="mb-8 pb-8 border-b border-gray-200">
            <div class="flex items-center gap-2 mb-4">
              <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-[#1B2A4A] text-white">Updated Proposal</span>
              <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-[#FF6B6B] text-white">v2.0</span>
              <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-emerald-600 text-white">Draft for sign-off</span>
            </div>
            <h1 class="text-3xl lg:text-4xl font-bold text-[#1B2A4A] mb-3">
              Cloud9 Visualisation Tool: MVP Build Proposal
            </h1>
            <p class="text-lg text-[#6B7280] mb-4">
              Updated commercial structure for the delivery of the MVP
            </p>
            <div class="flex flex-wrap gap-4 text-sm text-[#6B7280]">
              <span>Date: May 2026</span>
              <span>&bull;</span>
              <span>Version: 2.0</span>
              <span>&bull;</span>
              <span>Supersedes the commercial terms in Proposal V2.1 (20 Feb 2026); technical scope unchanged</span>
            </div>
          </div>

          <!-- 1. Executive Summary -->
          <section data-section="executive-summary" class="proposal-section hidden">
            <h2 class="text-2xl lg:text-3xl font-bold text-[#1B2A4A] mb-6">1. Executive Summary</h2>

            <p class="text-[#2D2D2D] leading-relaxed mb-4">
              This proposal sets out the commercial structure for BrightKeep to deliver the Cloud9 Visualisation Tool MVP, including initial deployments to Cloud9 and to Cleanaway as the first end client. Payment terms reflect the product's onboarding and growth profile, with milestones tied to delivery events.
            </p>

            <div class="grid md:grid-cols-2 gap-4 mb-6">
              <div class="p-5 rounded-lg bg-[#1B2A4A] text-white">
                <p class="text-xs uppercase tracking-wider text-[#FF6B6B] mb-2">MVP Build, fixed fee</p>
                <p class="text-3xl font-bold mb-1">$38,900</p>
                <p class="text-sm text-white/80">excl. GST. $42,790 incl. GST.</p>
                <p class="text-xs text-white/60 mt-3">Paid across four milestones (3 &times; $10,000 and a final of $8,900), each on Net 60 terms, tied to defined delivery events.</p>
              </div>
              <div class="p-5 rounded-lg bg-emerald-700 text-white">
                <p class="text-xs uppercase tracking-wider text-emerald-200 mb-2">Target delivery dates</p>
                <ul class="text-sm space-y-2">
                  <li><strong class="block text-white">29 May 2026</strong><span class="text-white/80">Cloud9 internal working solution (PoC)</span></li>
                  <li><strong class="block text-white">12 June 2026</strong><span class="text-white/80">Cleanaway production go-live</span></li>
                </ul>
                <p class="text-xs text-white/60 mt-3">Dates assume contract signature in the next sitting and timely Cloud9 / Cleanaway readiness on infrastructure and data.</p>
              </div>
            </div>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mt-8 mb-3">The Headline</h3>
            <ul class="list-disc pl-6 space-y-2 text-[#2D2D2D]">
              <li><strong>Fixed price, fixed scope.</strong> $38,900 excl. GST covers the MVP feature set plus deployment to Cloud9 as Proof of Concept and to Cleanaway as the first end client. Not time-and-materials.</li>
              <li><strong>Four-milestone payment structure.</strong> $10,000 excl. GST at signature, Cloud9 PoC handover, and Cleanaway production deployment. A final $8,900 on acceptance after a one-month stabilisation period. Each invoice is payable Net 60.</li>
              <li><strong>Cloud9 PoC by 29 May, Cleanaway live by 12 June.</strong> Cloud9 is the first internal user, with the working solution in their tenant ahead of Cleanaway's go-live. PoC acceptance demonstrates the MVP working end-to-end against real data.</li>
              <li><strong>Development is its own stream.</strong> This contract covers the MVP only. Any post-MVP development of the Visualisation Tool will be agreed in a future development contract or contract update, separate from any consulting work.</li>
            </ul>
          </section>

          <!-- 2. Engagement Structure -->
          <section data-section="two-contracts" class="proposal-section hidden">
            <h2 class="text-2xl lg:text-3xl font-bold text-[#1B2A4A] mb-6">2. Engagement Structure</h2>

            <p class="text-[#2D2D2D] leading-relaxed mb-6">
              The commercial relationship between Cloud9 and BrightKeep runs across three workstreams. Each has its own contract. This proposal covers Workstream A only. The other two are listed for context so that the boundary of this contract is clear.
            </p>

            <div class="overflow-x-auto mb-8">
              <table>
                <thead>
                  <tr>
                    <th>Workstream</th>
                    <th>Scope</th>
                    <th>Contract</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><strong>A. MVP Build</strong><br/><span class="text-xs text-[#6B7280]">(this proposal)</span></td>
                    <td>Development of the Visualisation Tool MVP, with deployment to Cloud9's own SharePoint as Proof of Concept and to Cleanaway as the first end client</td>
                    <td>MVP Build Contract</td>
                    <td>Proposed (this document)</td>
                  </tr>
                  <tr>
                    <td><strong>B. Post-MVP Development</strong></td>
                    <td>Subsequent development of the Visualisation Tool. Further client deployments, MLP features, backlog items, AI features, ongoing maintenance.</td>
                    <td>Future development contracts or contract updates, agreed as the work is scoped</td>
                    <td>Not covered here; deferred to future agreement</td>
                  </tr>
                  <tr>
                    <td><strong>C. Consulting</strong></td>
                    <td>Consulting services to Cloud9 in support of NAB and other Cloud9 client engagements</td>
                    <td>Separate Consultancy Agreement</td>
                    <td>Drafted, pending amendments</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="p-5 rounded-lg bg-[#F8F9FA] border-l-4 border-[#FF6B6B]">
              <p class="font-semibold text-[#1B2A4A] mb-2">Development work sits separately from consulting</p>
              <p class="text-sm text-[#2D2D2D]">
                Workstreams A and B cover development of the Visualisation Tool. Workstream C covers consulting for NAB and other Cloud9 clients. The two are kept on different contracts. Development is delivered under fixed-scope work, not against the Consultancy Agreement. Keeping them apart avoids confusion about which obligations, IP terms and payment terms apply to which piece of work.
              </p>
            </div>
          </section>

          <!-- 3. MVP Scope -->
          <section data-section="mvp-scope" class="proposal-section hidden">
            <h2 class="text-2xl lg:text-3xl font-bold text-[#1B2A4A] mb-6">3. MVP Scope</h2>

            <p class="text-[#2D2D2D] leading-relaxed mb-6">
              The MVP feature set is unchanged from the V1 proposal (Section 9). This proposal adds an explicit scope lock. Anything not listed below is out of scope of this contract and is to be agreed under a future development contract.
            </p>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mb-3">3.1 Functional scope (in)</h3>
            <div class="overflow-x-auto mb-8">
              <table>
                <thead>
                  <tr><th>Capability</th><th>Detail</th></tr>
                </thead>
                <tbody>
                  <tr><td>Interactive integration map</td><td>Drag, zoom, pan; force-directed and orthogonal layouts</td></tr>
                  <tr><td>Multi-dimensional filtering</td><td>Application, domain, protocol, tags, business process; real-time re-render</td></tr>
                  <tr><td>Degree of hops</td><td>Select node, set 1&ndash;N hop count; directional BFS (upstream/downstream/both)</td></tr>
                  <tr><td>Application catalogue</td><td>Searchable, sortable; user-managed colour assignment</td></tr>
                  <tr><td>Integration catalogue</td><td>Source/target, protocol, direction, business process, data contracts</td></tr>
                  <tr><td>SharePoint integration</td><td>Native SharePoint Online integration via Microsoft Graph. Daily automated sync plus manual refresh. Read-only, one-way data flow from the client's Applications and Integrations lists.</td></tr>
                  <tr><td>Positions memory and named layouts</td><td>Save multiple graph arrangements per user</td></tr>
                  <tr><td>PNG and PDF export</td><td>Built-in presets (Quick, Standard, Full Detail)</td></tr>
                  <tr><td>Microsoft SSO</td><td>Entra ID with MFA</td></tr>
                  <tr><td>Role-based access control (RBAC)</td><td>Multiple user roles defined and enforced via Entra ID groups (e.g. Read-only, Editor, Administrator). Permissions applied in-application against role membership.</td></tr>
                  <tr><td>Single-tenant deployment</td><td>Per-client isolated Azure instance, deployed via Terraform</td></tr>
                </tbody>
              </table>
            </div>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mb-3">3.2 Deployment scope (in)</h3>
            <p class="text-[#2D2D2D] leading-relaxed mb-3">The fixed fee covers two deployments using BrightKeep's deployment pipeline:</p>
            <ol class="list-decimal pl-6 space-y-2 mb-8 text-[#2D2D2D]">
              <li><strong>Cloud9 internal deployment.</strong> Deployed to Cloud9's own SharePoint and Azure subscription. This serves as the Proof of Concept and the acceptance environment.</li>
              <li><strong>Cleanaway first-client deployment.</strong> Production deployment to Cleanaway's environment using the same pipeline. Includes pre-deployment, infrastructure provisioning, data integration, UAT, training and handover.</li>
            </ol>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mb-3">3.3 Technical hygiene (BrightKeep's cost)</h3>
            <p class="text-[#2D2D2D] leading-relaxed mb-6">
              Items of architectural hygiene, bug fixes, test coverage uplift and TRD alignment work (CI workflow, test tooling, library version updates, and similar) are <strong>not</strong> part of this fixed fee. BrightKeep covers them at its own cost as part of delivering a working MVP.
            </p>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mb-3">3.4 Out of scope (explicit)</h3>
            <div class="overflow-x-auto mb-6">
              <table>
                <thead>
                  <tr><th>Out of scope</th><th>Where it goes</th></tr>
                </thead>
                <tbody>
                  <tr><td>Deployments to clients beyond Cloud9 and Cleanaway</td><td>Future development contract or the existing Consulting Agreement</td></tr>
                  <tr><td>Non-SharePoint third-party integrations (e.g. ServiceNow, ManageEngine, ITSM platforms, CMDBs)</td><td>Future development contract, scoped per integration</td></tr>
                  <tr><td>MLP features (multi-persona, check-out model, tenant branding, operations dashboard, full validation rules)</td><td>Future development contract, scoped per Statement of Work</td></tr>
                  <tr><td>Tier 2 backlog (business owner display, criticality badge, hosting type, dynamic metadata filters)</td><td>Future development contract</td></tr>
                  <tr><td>Tier 3 backlog (scenario modelling, sync changelog, lifecycle date, cost per app, calculated risk score)</td><td>Future development contract</td></tr>
                  <tr><td>Tier 4 (capability mapping, reference catalog, automated discovery, GRC, historical trending)</td><td>Future development contract, or formally parked</td></tr>
                  <tr><td>AI features (conversational filtering, solution design advisor)</td><td>Future development contract, separate engagement</td></tr>
                  <tr><td>Ongoing maintenance and support after acceptance</td><td>Future development contract, ad-hoc</td></tr>
                </tbody>
              </table>
            </div>

            <div class="p-5 rounded-lg bg-amber-50 border border-amber-200">
              <p class="font-semibold text-[#1B2A4A] mb-2">Change control</p>
              <p class="text-sm text-[#2D2D2D]">
                Any request from Cloud9 for work outside Sections 3.1 or 3.2 during the MVP build is treated as a Change Request. Work on a Change Request does not start until the change is documented in writing, and the parties have agreed either to defer it to a future development contract or to add it to this contract via a signed variation with a matching fee adjustment. Both parties rely on this clause to keep costs and timelines predictable.
              </p>
            </div>
          </section>

          <!-- 4. Proof of Concept -->
          <section data-section="poc" class="proposal-section hidden">
            <h2 class="text-2xl lg:text-3xl font-bold text-[#1B2A4A] mb-6">4. Proof of Concept and Acceptance</h2>

            <p class="text-[#2D2D2D] leading-relaxed mb-6">
              The MVP is deployed to Cloud9's internal SharePoint environment as the Proof of Concept, with Cloud9 as the first internal user. The deployment shows the MVP running against real Cloud9 data, and forms the basis for acceptance under this contract.
            </p>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mb-3">4.1 PoC environment</h3>
            <div class="overflow-x-auto mb-6">
              <table>
                <thead><tr><th>Item</th><th>Detail</th></tr></thead>
                <tbody>
                  <tr><td>Hosting</td><td>Cloud9 Azure subscription (existing)</td></tr>
                  <tr><td>Data source</td><td>Cloud9's internal SharePoint Applications and Integrations lists</td></tr>
                  <tr><td>Users</td><td>Cloud9 staff via Entra ID SSO</td></tr>
                  <tr><td>Infrastructure</td><td>Provisioned per the standard Terraform configuration delivered as part of the MVP</td></tr>
                </tbody>
              </table>
            </div>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mb-3">4.2 PoC acceptance criteria (Milestone 2)</h3>
            <p class="text-[#2D2D2D] leading-relaxed mb-3">The Cloud9 PoC is accepted, and Milestone 2 is reached, when the following are demonstrated:</p>
            <ol class="list-decimal pl-6 space-y-2 mb-6 text-[#2D2D2D]">
              <li>The application is deployed and accessible via the configured Cloud9 URL</li>
              <li>SharePoint sync runs successfully against Cloud9's internal SharePoint data</li>
              <li>All functional capabilities listed in Section 3.1 operate as specified</li>
              <li>Microsoft SSO authentication succeeds for Cloud9 users</li>
              <li>PNG and PDF export produce valid output from the loaded data</li>
            </ol>

            <p class="text-[#2D2D2D] leading-relaxed mb-3">
              Cloud9 has <strong>10 business days</strong> from the PoC handover demonstration to confirm acceptance or notify BrightKeep in writing of specific acceptance failures against the criteria above. If no such notification is received within that window, the PoC is deemed accepted.
            </p>

            <p class="text-[#2D2D2D] leading-relaxed mb-3">
              Final acceptance, covering the Cleanaway deployment and the handover bundle, is reached at Milestone 4 after the one-month stabilisation period. The full transition path is set out in Section 5.3.
            </p>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mt-8 mb-3">4.3 Defect resolution within acceptance</h3>
            <p class="text-[#2D2D2D] leading-relaxed">
              Defects raised in the acceptance window that fall within Section 3.1 are resolved by BrightKeep at no additional charge prior to acceptance. Items raised that fall outside Section 3.1 are not defects. They are change requests and follow Section 3.4.
            </p>
          </section>

          <!-- 5. Commercial Terms -->
          <section data-section="commercials" class="proposal-section hidden">
            <h2 class="text-2xl lg:text-3xl font-bold text-[#1B2A4A] mb-6">5. Commercial Terms</h2>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mb-3">5.1 Fee</h3>
            <div class="p-5 rounded-lg bg-[#1B2A4A] text-white mb-6">
              <p class="text-xs uppercase tracking-wider text-[#FF6B6B] mb-1">Total fixed fee</p>
              <p class="text-3xl font-bold">$38,900 AUD excl. GST</p>
              <p class="text-sm text-white/80 mt-1">$42,790 AUD incl. GST</p>
            </div>

            <p class="text-[#2D2D2D] leading-relaxed mb-6">
              The fee is <strong>fixed</strong>, not time-and-materials. BrightKeep carries the risk of any overrun on the scoped items in Sections 3.1 and 3.2 and on the hygiene work in Section 3.3. The fee covers the complete MVP feature set together with the Cloud9 PoC deployment and the Cleanaway first-client deployment.
            </p>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mb-3">5.2 Payment schedule</h3>

            <p class="text-[#2D2D2D] leading-relaxed mb-4">
              The total fee is paid in four milestones: $10,000 excl. GST at each of the first three milestones, and $8,900 excl. GST at final acceptance. Payment terms are <strong>Net 60</strong> on each milestone invoice, set to reflect the product's onboarding and growth profile.
            </p>

            <div class="overflow-x-auto mb-6">
              <table>
                <thead>
                  <tr>
                    <th>Milestone</th>
                    <th>Trigger</th>
                    <th>Target date</th>
                    <th class="text-right">Amount excl. GST</th>
                    <th>Terms</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><strong>M1. Mobilisation</strong></td>
                    <td>Contract signature</td>
                    <td>On signature</td>
                    <td class="text-right">$10,000</td>
                    <td>Net 60</td>
                  </tr>
                  <tr>
                    <td><strong>M2. Cloud9 PoC handover</strong></td>
                    <td>MVP deployed to Cloud9's SharePoint per Section 4.2</td>
                    <td>29 May 2026</td>
                    <td class="text-right">$10,000</td>
                    <td>Net 60</td>
                  </tr>
                  <tr>
                    <td><strong>M3. Cleanaway production deployment</strong></td>
                    <td>MVP deployed and operational in Cleanaway's environment</td>
                    <td>12 June 2026</td>
                    <td class="text-right">$10,000</td>
                    <td>Net 60</td>
                  </tr>
                  <tr>
                    <td><strong>M4. Final acceptance and ownership transfer</strong></td>
                    <td>One-month stabilisation period complete after Cleanaway production go-live. Cloud9 confirms final acceptance covering the Cloud9 PoC, the Cleanaway deployment, and the handover bundle. Title transfers per Section 7.</td>
                    <td>13 July 2026</td>
                    <td class="text-right">$8,900</td>
                    <td>Net 60</td>
                  </tr>
                  <tr class="total-row">
                    <td colspan="3"><strong>Total</strong></td>
                    <td class="text-right"><strong>$38,900</strong></td>
                    <td></td>
                  </tr>
                </tbody>
              </table>
            </div>

            <p class="text-[#2D2D2D] leading-relaxed mb-6">
              Milestone invoices are issued on the day the milestone is reached and are payable Net 60. GST is added to each invoice and is payable concurrently with the invoice amount.
            </p>

            <h3 class="text-xl font-semibold text-[#1B2A4A] mb-3">5.3 Transition to Milestone 4 (Final Acceptance)</h3>

            <p class="text-[#2D2D2D] leading-relaxed mb-4">
              M1 to M3 are tied to discrete delivery events. M4 is structured differently. It is reached after a one-month stabilisation period following Cleanaway production go-live, giving real-world usage time before final acceptance and ownership transfer.
            </p>

            <p class="text-[#2D2D2D] leading-relaxed mb-3">
              The transition from M3 to M4 works as follows:
            </p>

            <ol class="list-decimal pl-6 space-y-2 mb-6 text-[#2D2D2D]">
              <li><strong>Cleanaway production go-live (M3)</strong>. Tool deployed and operational in Cleanaway's environment. M3 invoice is issued.</li>
              <li><strong>One-month stabilisation period</strong>. The tool runs in production at Cleanaway. BrightKeep monitors for any defects falling within Section 3.1, and resolves them at no additional charge as part of M4 delivery. Any items raised that fall outside Section 3.1 are change requests and are deferred to a future development contract per Section 3.4.</li>
              <li><strong>Final acceptance review</strong>. At the end of the stabilisation period, Cloud9 reviews the complete delivery (Cloud9 PoC + Cleanaway deployment + handover bundle) and confirms acceptance. If specific acceptance failures are identified in writing referencing Section 3.1, BrightKeep resolves them and the review repeats. Absent such notification within 10 business days of the end of the stabilisation period, acceptance is deemed given.</li>
              <li><strong>Ownership transfer</strong>. On acceptance (or deemed acceptance), title transfers to Cloud9 per Section 7.2. The full handover bundle is delivered, including transfer of the GitHub repository, deployment pipeline, and admin access to the deployed instances. M4 invoice is issued.</li>
            </ol>

            <p class="text-[#2D2D2D] leading-relaxed">
              Target date for M4 is 13 July 2026, being one month after the 12 June 2026 Cleanaway go-live target. If M3 lands later than 12 June, M4 moves out by the same number of days.
            </p>
          </section>

          <!-- 6. Infrastructure Costs -->
          <section data-section="infrastructure" class="proposal-section hidden">
            <h2 class="text-2xl lg:text-3xl font-bold text-[#1B2A4A] mb-6">6. Infrastructure and Hosting Costs</h2>

            <p class="text-[#2D2D2D] leading-relaxed mb-4">
              Infrastructure costs are not borne by BrightKeep. They are paid by the party hosting each instance of the tool. For the Cloud9 internal deployment, this is Cloud9. For the Cleanaway production deployment, this is the party hosting that instance (Cleanaway directly, or Cloud9 hosting on Cleanaway's behalf, depending on the deployment arrangement agreed between Cloud9 and Cleanaway).
            </p>

            <p class="text-[#2D2D2D] leading-relaxed mb-6">
              Infrastructure is billed by the hosting provider (Microsoft Azure for the current MVP architecture). BrightKeep applies no markup, no managed service fee, and no intermediary billing. The party paying for hosting pays the cloud provider directly.
            </p>

            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h3 class="text-xl font-semibold text-[#1B2A4A]">6.1 Baseline cost (current MVP architecture)</h3>
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800 border border-emerald-300">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                Expected cost at this scope
              </span>
            </div>

            <p class="text-[#2D2D2D] leading-relaxed mb-4">
              Based on the current MVP architecture and Azure retail pricing (Australia East, AUD, May 2026):
            </p>

            <div class="overflow-x-auto cost-table-baseline mb-6">
              <table>
                <thead>
                  <tr>
                    <th>Resource</th>
                    <th>Detail</th>
                    <th class="text-right">Monthly cost (AUD)</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>App Service</td>
                    <td>B1 Basic Linux, single instance</td>
                    <td class="text-right">~$20</td>
                  </tr>
                  <tr>
                    <td>PostgreSQL</td>
                    <td>Burstable B1ms, 32GB storage</td>
                    <td class="text-right">~$33</td>
                  </tr>
                  <tr>
                    <td>Blob Storage</td>
                    <td>Standard LRS, low usage</td>
