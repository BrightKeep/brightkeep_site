          border-color: #e5e7eb;
        }
        .proposal-section .cost-table-muted tbody tr:nth-child(odd) {
          background-color: #fafafa;
        }
        .proposal-section .cost-table-muted tbody tr:nth-child(even) {
          background-color: #f3f4f6;
        }
        .proposal-section .cost-table-muted tbody tr:hover {
          background-color: #e5e7eb;
        }

        /* ===== Print cover page ===== */
        /* Styles applied at top level so they always parse;
           display toggled via @media screen / @media print. */

        #print-cover {
          box-sizing: border-box !important;
          width: 210mm !important;
          height: 297mm !important;
          margin: 0 !important;
          padding: 0 !important;
          background-color: #1B2A4A !important;
          color: #ffffff !important;
          position: relative !important;
          overflow: hidden !important;
          page-break-after: always !important;
          break-after: page !important;
          -webkit-print-color-adjust: exact !important;
          print-color-adjust: exact !important;
          color-adjust: exact !important;
        }

        #print-cover * {
          -webkit-print-color-adjust: exact !important;
          print-color-adjust: exact !important;
          color-adjust: exact !important;
        }

        /* Top: BrightKeep wordmark */
        #print-cover .print-cover-logo-wrap {
          position: absolute !important;
          top: 24mm !important;
          left: 22mm !important;
          font-family: 'Poppins', system-ui, sans-serif !important;
          font-size: 36pt !important;
          font-weight: 300 !important;
          line-height: 1 !important;
        }
        #print-cover .print-cover-logo-bright { color: #ffffff !important; }
        #print-cover .print-cover-logo-keep { color: #FF6B6B !important; }

        /* Top right: status pill */
        #print-cover .print-cover-tag-wrap {
          position: absolute !important;
          top: 28mm !important;
          right: 22mm !important;
        }
        #print-cover .print-cover-tag {
          display: inline-block !important;
          color: #FF6B6B !important;
          font-size: 9pt !important;
          font-weight: 600 !important;
          text-transform: uppercase !important;
          letter-spacing: 0.15em !important;
          border: 1pt solid #FF6B6B !important;
          padding: 5pt 11pt !important;
          border-radius: 999px !important;
        }

        /* Centre: title block */
        #print-cover .print-cover-title-wrap {
          position: absolute !important;
          top: 110mm !important;
          left: 22mm !important;
          right: 22mm !important;
        }
        #print-cover .print-cover-title {
          font-size: 38pt !important;
          font-weight: 700 !important;
          line-height: 1.12 !important;
          color: #ffffff !important;
          letter-spacing: -0.01em !important;
          margin: 0 0 10pt 0 !important;
        }
        #print-cover .print-cover-subtitle {
          font-size: 20pt !important;
          font-weight: 300 !important;
          color: rgba(255, 255, 255, 0.85) !important;
          margin: 0 0 22pt 0 !important;
        }
        #print-cover .print-cover-rule {
          width: 60pt !important;
          height: 3pt !important;
          background-color: #FF6B6B !important;
          margin: 0 0 22pt 0 !important;
        }
        #print-cover .print-cover-date {
          font-size: 14pt !important;
          color: #ffffff !important;
          margin: 0 !important;
        }

        /* Bottom strip: footer */
        #print-cover .print-cover-foot {
          position: absolute !important;
          bottom: 24mm !important;
          left: 22mm !important;
          right: 22mm !important;
          padding-top: 12pt !important;
          border-top: 1pt solid rgba(255, 255, 255, 0.25) !important;
          font-size: 10pt !important;
          color: rgba(255, 255, 255, 0.75) !important;
        }
        #print-cover .print-cover-foot-left {
          float: left !important;
          margin: 0 !important;
        }
        #print-cover .print-cover-foot-right {
          float: right !important;
          margin: 0 !important;
        }
        #print-cover .print-cover-foot::after {
          content: "" !important;
          display: block !important;
          clear: both !important;
        }

        /* Hide cover on screen */
        @media screen {
          #print-cover {
            display: none !important;
          }
        }

        /* Print: page setup and rules */
        @page {
          size: A4;
          margin: 18mm 15mm 22mm 15mm;
        }
        @page :first {
          margin: 0;
        }

        @media print {
          /* Hide chrome */
          header,
          #proposal-sidebar,
          #sidebar-backdrop,
          #export-pdf-btn,
          #proposal-cover {
            display: none !important;
          }

          /* Reset body and main padding so @page margins control whitespace */
          body {
            margin: 0 !important;
            padding: 0 !important;
            background: #ffffff !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
          }
          main {
            margin: 0 !important;
            padding: 0 !important;
          }

          /* Show cover */
          #print-cover {
            display: block !important;
          }

          /* Body content sections - force a page break between each */
          .proposal-section {
            display: block !important;
            page-break-before: always;
            break-before: page;
          }

          .proposal-section table {
            page-break-inside: avoid;
            break-inside: avoid;
          }

          .proposal-section thead,
          .proposal-section tbody tr:nth-child(even),
          .proposal-section tr.total-row td,
          .proposal-section .cost-table-baseline tr.total-row td,
          .proposal-section .cost-table-muted thead tr {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
          }

          h2, h3 {
            page-break-after: avoid;
            break-after: avoid;
          }
        }
      </style>

      <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
          const sections = document.querySelectorAll('.proposal-section');
          const sidebarLinks = document.querySelectorAll('.sidebar-link');
          const cover = document.getElementById('proposal-cover');

          const exportBtn = document.getElementById('export-pdf-btn');
          if (exportBtn) {
            exportBtn.addEventListener('click', () => {
              const activeSection = document.querySelector('.proposal-section:not(.hidden)');
              const activeSectionId = activeSection ? activeSection.dataset.section : 'executive-summary';

              sections.forEach(s => s.classList.remove('hidden'));
              if (cover) cover.classList.remove('hidden');

              setTimeout(() => { window.print(); }, 200);

              window.addEventListener('afterprint', function restore() {
                window.removeEventListener('afterprint', restore);
                sections.forEach(s => s.classList.add('hidden'));
                showSection(activeSectionId);
              });
            });
          }

          window.showSection = showSection;
          function showSection(sectionId) {
            if (cover) cover.classList.add('hidden');
            sections.forEach(s => s.classList.add('hidden'));
            const target = document.querySelector(`section[data-section="${sectionId}"]`);
            if (target) {
              target.classList.remove('hidden');
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
            sidebarLinks.forEach(link => {
              link.classList.remove('bg-[#1B2A4A]', 'text-white', 'font-medium');
              if (link.dataset.section === sectionId) {
                link.classList.add('bg-[#1B2A4A]', 'text-white', 'font-medium');
              }
            });
            closeMobileSidebar();
          }

          sidebarLinks.forEach(link => {
            link.addEventListener('click', () => {
              showSection(link.dataset.section);
            });
          });

          const sidebarToggle = document.getElementById('sidebar-toggle');
          const sidebar = document.getElementById('proposal-sidebar');
          const backdrop = document.getElementById('sidebar-backdrop');

          function openMobileSidebar() {
            sidebar.classList.remove('-translate-x-full');
            backdrop.classList.remove('hidden');
          }

          function closeMobileSidebar() {
            if (window.innerWidth < 1024) {
              sidebar.classList.add('-translate-x-full');
              backdrop.classList.add('hidden');
            }
          }

          if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
              if (sidebar.classList.contains('-translate-x-full')) {
                openMobileSidebar();
              } else {
                closeMobileSidebar();
              }
            });
          }

          if (backdrop) {
            backdrop.addEventListener('click', closeMobileSidebar);
          }

          showSection('executive-summary');
        });
      </script>
    </>
  )}
</ProposalLayout>
